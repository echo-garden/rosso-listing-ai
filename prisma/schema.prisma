generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                   String            @id @default(cuid())
  title                String?
  productType          String
  condition            String
  brandName            String?
  characterName        String?
  size                 String?
  color                String?
  costPrice            Int?
  salePrice            Int?
  staffMemo            String?
  status               ProductStatus     @default(draft)
  mercariProductId     String?
  mercariProductStatus String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  images               ProductImage[]
  generatedContent     GeneratedContent?
  analysis             ProductAnalysis?
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  storageKey String
  imageRole String   @default("product")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model GeneratedContent {
  id                     String   @id @default(cuid())
  productId              String   @unique
  mercariTitle           String
  mercariDescription     String
  instagramCaption       String
  onlineStoreDescription String
  hashtags               String
  priceSuggestion        String
  conditionText          String
  checkPoints            String
  riskWarnings           String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  product                Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductAnalysis {
  id                    String   @id @default(cuid())
  productId             String   @unique
  productType           String?
  productTypeConfidence Float?
  brandName             String?
  brandConfidence       Float?
  brandCandidates       Json?
  characterName         String?
  characterConfidence   Float?
  size                  String?
  sizeConfidence        Float?
  color                 String?
  colorConfidence       Float?
  conditionSummary      String?
  tags                  String?
  priceMin              Int?
  priceMax              Int?
  recommendedPrice      Int?
  priceReason           String?
  warnings              String?
  referenceSources      Json?
  rawJson               Json?
  mockMode              Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProductStatus {
  draft
  generated
  mercari_unopened
  mercari_opened
  listed_other
  sold
  archived
}
